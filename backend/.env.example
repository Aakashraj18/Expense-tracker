# ─── Server ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB ────────────────────────────────────────────────────────────────
#MONGO_URI=mongodb://127.0.0.1:27017/expense_tracker
# For production Atlas:
MONGO_URI=mongodb+srv://akashkrrajak18_db_user:n7twVDvW32cvPLBl@cluster.mongodb.net/expense_tracker?retryWrites=true&w=majority

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_strong_256bit_secret_key_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_a_different_256bit_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# ─── Encryption ─────────────────────────────────────────────────────────────
# Used to encrypt tenant API keys stored in DB
ENCRYPTION_SECRET=replace_with_32char_encryption_key_here_!!

# ─── Rate Limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs
